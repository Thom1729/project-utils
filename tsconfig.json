{
  "compilerOptions": {
    "lib": ["es2022", "DOM"],
    "target": "es2022",
    "declaration": true,
    "declarationDir": "./dist/esm",

    "module": "esnext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "paths": {
      "@": ["src"],
      "@/*": ["src/*"],
    },
    "forceConsistentCasingInFileNames": true,

    "strict": true
  },
}
